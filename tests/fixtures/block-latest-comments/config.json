{
	"$schema": "../../fixtures.config.schema.json",
	"editor-search-replace": [
		{
			"search": "<time([^>]*)>[\\s\\S]*?</time>",
			"replace": "<time$1>Month Day, Year</time>"
		},
		{
			"search": "datetime=([\"'])[^\"']*\\1",
			"replace": "datetime=\"Month Day, Year\""
		}
	],
	"frontend-search-replace": [
		{
			"search": "<time datetime=\"[^\"]+\"( class=\"[^\"]+\")?>(<a[^>]*>)?[^<]*(</a>)?</time>",
			"replace": "<time datetime=\"Month Day, Year\"$1>$2Month Day, Year$3</time>"
		}
	]
}

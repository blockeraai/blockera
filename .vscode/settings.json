{
	"files.eol": "\n",
	"cSpell.customDictionaries": {
		"custom-dictionary-folder-blockera": {
			"name": "custom-dictionary-folder-blockera",
			"path": "${workspaceFolder:blockera}/.cspell/custom-dictionary-folder-blockera.txt",
			"addWords": true,
			"scope": "folder"
		}
	},
	"css.validate": false,
	"scss.validate": false,
	"less.validate": false,
	"stylelint.enable": true,
	"stylelint.validate": ["css", "scss", "less"],
	"stylelint.configFile": ".stylelintrc.js",
	"stylelint.snippet": ["css", "scss", "less"],
	"files.associations": {
		"*.scss": "scss"
	},
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"[css]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	},
	"[scss]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	},
	"[less]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	},
	"prettier.enable": true,
	"prettier.configPath": ".prettierrc.js",
	"prettier.requireConfig": true
}

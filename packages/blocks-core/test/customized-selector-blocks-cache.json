{
	"core/paragraph": {
		"root": "p",
		"typography": {
			"textIndent": ".wp-block-paragraph + .wp-block-paragraph"
		}
	},
	"core/image": {
		"border": ".wp-block-image :is(img, svg, .wp-block-image__crop-area, .components-placeholder, .block-editor-media-placeholder::before, .components-resizable-box__container::before)",
		"shadow": ".wp-block-image :is(img, svg, .wp-block-image__crop-area, .components-placeholder, .block-editor-media-placeholder::before, .components-resizable-box__container::before)",
		"filter": ".wp-block-image :is(img, svg, .wp-block-image__crop-area, .components-placeholder, .block-editor-media-placeholder::before, .components-resizable-box__container::before)",
		"width": ".wp-block-image :is(img, svg, .wp-block-image__crop-area, .components-placeholder, .block-editor-media-placeholder::before, .components-resizable-box__container::before)",
		"object-fit": ".wp-block-image :is(img, svg, .wp-block-image__crop-area, .components-placeholder, .block-editor-media-placeholder::before, .components-resizable-box__container::before)",
		"box-sizing": ".wp-block-image :is(img, svg, .wp-block-image__crop-area, .components-placeholder, .block-editor-media-placeholder::before, .components-resizable-box__container::before)",
		"border-radius": ".wp-block-image :is(img, svg, .wp-block-image__crop-area, .components-placeholder, .block-editor-media-placeholder::before, .components-resizable-box__container::before)"
	},
	"core/list": {
		"border": "ul"
	},
	"core/list-item": {
		"root": ".wp-block-list > li",
		"border": ".wp-block-list:not(.wp-block-list .wp-block-list) > li"
	},
	"core/accordion-heading": {
		"typography": {
			"letterSpacing": ".wp-block-accordion-heading .wp-block-accordion-heading__toggle-title",
			"textDecoration": ".wp-block-accordion-heading .wp-block-accordion-heading__toggle-title"
		},
		"spacing": {
			"root": " .wp-block-accordion-heading__toggle"
		}
	},
	"core/archives": {
		"root": " .wp-block-archives-list.wp-block-archives"
	},
	"core/audio": {
		"spacing": {
			"root": ".wp-block-audio audio::-webkit-media-controls-enclosure"
		},
		"background": {
			"root": ".wp-block-audio audio::-webkit-media-controls-enclosure"
		},
		"border": {
			"root": ".wp-block-audio audio::-webkit-media-controls-enclosure"
		},
		"shadow": {
			"root": ".wp-block-audio audio"
		},
		"width": {
			"root": ".wp-block-audio audio"
		},
		"dimensions": {
			"root": ".wp-block-audio audio"
		}
	},
	"core/button": {
		"root": ".wp-block-button .wp-block-button__link",
		"typography": {
			"writingMode": ".wp-block-button"
		},
		"color": {
			"root": " .wp-block-button__link"
		},
		"flex-child": {
			"root": ".wp-block-button"
		},
		"htmlEditable": {
			"root": ".wp-block-button .wp-block-button__link"
		}
	},
	"core/calendar": {
		"root": ".wp-block-calendar[data-block]"
	},
	"core/cover": {
		"filter": {
			"duotone": ".wp-block-cover > .wp-block-cover__image-background, .wp-block-cover > .wp-block-cover__video-background"
		}
	},
	"core/embed": {
		"root": " .wp-block-embed__wrapper",
		"spacing": ".wp-block-embed",
		"layout": ".wp-block-embed",
		"effects": ".wp-block-embed",
		"position": ".wp-block-embed"
	},
	"core/file": {
		"layout": " .wp-block-file__content-wrapper"
	},
	"core/latest-comments": {
		"root": ".wp-block-latest-comments[data-block]"
	},
	"core/rss": {
		"root": ".wp-block-rss[data-block]"
	},
	"core/social-link": {
		"layout": ".wp-block-social-link .wp-block-social-link-anchor",
		"flex-child": ".wp-block-social-link"
	},
	"core/table": {
		"root": ".wp-block-table > table",
		"spacing": ".wp-block-table"
	},
	"core/tag-cloud": {
		"layout": " .wp-block-tag-cloud"
	},
	"core/navigation-link": {
		"root": ".wp-block-navigation-link",
		"htmlEditable": {
			"root": " .wp-block-navigation-item__content .wp-block-navigation-item__label"
		}
	},
	"core/navigation-submenu": {
		"root": ".wp-block-navigation-submenu:is(li,[data-type=\"core/navigation-submenu\"])",
		"htmlEditable": {
			"root": " a.wp-block-navigation-item__content span.wp-block-navigation-item__label"
		}
	},
	"core/site-logo": {
		"filter": ".wp-block-site-logo :is(img)",
		"width": ".wp-block-site-logo :is(img)"
	},
	"core/site-title": {
		"htmlEditable": {
			"root": ".wp-block-site-title a"
		}
	},
	"core/avatar": {
		"border": ".wp-block-avatar img",
		"filter": {
			"duotone": ".wp-block-avatar img"
		},
		"shadow": ".wp-block-avatar img"
	},
	"core/post-featured-image": {
		"border": ".wp-block-post-featured-image img",
		"shadow": ".wp-block-post-featured-image img",
		"filter": ".wp-block-post-featured-image img",
		"radius": ".wp-block-post-featured-image img"
	},
	"core/post-author": {
		"filter": {
			"duotone": ".wp-block-post-author .wp-block-post-author__avatar img"
		}
	},
	"core/query-pagination-next": {
		"root": ".wp-block-query-pagination-next"
	},
	"core/query-pagination-numbers": {
		"root": ".wp-block-query-pagination-numbers"
	},
	"core/query-pagination-previous": {
		"root": ".wp-block-query-pagination-previous"
	},
	"core/comments-pagination-next": {
		"root": ".wp-block-comments-pagination-next"
	},
	"core/comments-pagination-numbers": {
		"root": ".wp-block-comments-pagination-numbers"
	},
	"core/comments-pagination-previous": {
		"root": ".wp-block-comments-pagination-previous"
	},
	"core/home-link": {
		"htmlEditable": {
			"root": " .wp-block-home-link__content"
		}
	},
	"core/icon": {
		"root": ".wp-block-icon svg",
		"css": ".wp-block-icon",
		"spacing": {
			"margin": "&.wp-block-icon",
			"padding": "&.wp-block-icon"
		},
		"color": {
			"root": "&.wp-block-icon svg"
		},
		"border": {
			"root": "&.wp-block-icon svg"
		},
		"border-radius": {
			"root": "&.wp-block-icon svg"
		},
		"width": {
			"root": "&.wp-block-icon svg"
		},
		"htmlEditable": {
			"root": "&.wp-block-icon svg"
		}
	},
	"core/breadcrumbs": {
		"layout": ".wp-block-breadcrumbs ol"
	}
}

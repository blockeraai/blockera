{
	"name": "blockera/blockera",
	"version": "1.3.3",
	"description": "The bootstrapper for blockera php application for WordPress in admin and front-end sides.",
	"autoload": {
		"psr-4": {
			"Blockera\\Setup\\": "php/"
		},
		"files": [
			"php/functions.php",
			"php/Compatibility/rest-api-helpers.php",
			"php/Compatibility/block-template-utils.php",
			"php/Compatibility/Blocks/template-part.php",
			"php/Compatibility/BlockSupports/layout.php",
			"php/Compatibility/BlockSupports/typography.php",
			"php/Compatibility/global-styles-and-settings.php",
			"php/Compatibility/fonts.php",
			"php/Compatibility/BlockSupports/block-style-variations.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Blockera\\Setup\\Tests\\": "php/tests/"
		}
	}
}
